---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style is:global>
      :root {
        --bg-primary: #040404;
        --surface: #0D0F12;
        --text-primary: #F3F4F6;
        --text-secondary: #9CA3AF;
        --accent-gold: #D4AF37;
        --accent-blue: #6366F1;
      }
      html {
        font-family: system-ui, -apple-system, sans-serif;
        background-color: var(--bg-primary);
        color: var(--text-primary);
        margin: 0;
        padding: 0;
      }
      body {
        margin: 0;
        padding: 0;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
