---
interface Props { id: string; title: string; description: string; status: string; href: string; }
const { id, title, description, status, href } = Astro.props;
---
<a href={href} class="nexus-card">
  <div class="card-top">
    <span class="card-id">{id}</span>
    <span class="card-indicator">● ONLINE</span>
  </div>
  <div class="card-content">
    <h2 class="card-title">{title}</h2>
    <p class="card-description">{description}</p>
  </div>
  <div class="card-footer">
    <span class="card-status">{status}</span>
    <span class="card-enter">ENTER →</span>
  </div>
</a>

<style>
  .nexus-card { 
    display: flex; flex-direction: column; justify-content: space-between;
    min-height: 280px; padding: 32px; background: var(--surface-2);
    border: 1px solid rgba(255,255,255,0.06); text-decoration: none;
    transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }
  .nexus-card:hover { transform: translateY(-2px); background: var(--surface-3); border-color: var(--accent-gold); }
  .nexus-card:focus-visible { outline: 2px solid var(--accent-gold); outline-offset: 4px; }
  .card-top, .card-footer { display: flex; justify-content: space-between; align-items: center; }
  .card-id, .card-indicator, .card-status, .card-enter { font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.08em; }
  .card-title { margin: 0 0 12px 0; font-size: 1.4rem; color: var(--text-primary); }
  .card-description { margin: 0; line-height: 1.6; color: var(--text-secondary); }
  .card-status { color: var(--accent-gold); }
  .card-enter { color: var(--accent-blue); }
</style>
