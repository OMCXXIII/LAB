---
interface Props {
  nodes: string[];
}

const { nodes } = Astro.props;
---

<section class="system-status">

  {nodes.map((node) => (
    <div class="status-node">
      {node}
    </div>
  ))}

</section>

<style>
.system-status{
  display:flex;
  flex-wrap:wrap;
  gap:1rem;
  margin-bottom:3rem;
}

.status-node{
  border:1px solid rgba(255,255,255,.08);
  background:rgba(255,255,255,.02);
  padding:.8rem 1rem;
  font-size:.75rem;
  letter-spacing:.1em;
  color:var(--text-secondary);
  font-family:monospace;
}
</style>
