---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Engenharia da Consciência // Expansão">
  <main class="lab-container">
    <header class="lab-header">
      <a href="/LAB/" class="back-link">VOLTAR AO KERNEL</a>
      <div class="hud-badge">ENGENHARIA DA CONSCIÊNCIA // STATUS: EXPANSÃO</div>
      <h1 class="lab-title">Modelagem Lógica e Significado</h1>
      <p class="lab-subtitle">Desconstrução estrutural do ego, sistemas de percepção e obras literárias associadas.</p>
    </header>

    <section class="dashboard-grid">
      <div class="data-panel">
        <div class="panel-header">
          <h2>Obras e Publicações</h2>
          <span class="pulse-indicator"></span>
        </div>
        <div class="metrics-list">
          <a href="LINK_AMAZON_AQUI" class="metric-item" target="_blank" style="text-decoration: none;">
            <span class="metric-label">Engenharia da Maestria (E-book)</span>
            <span class="metric-value text-gold">AMAZON -></span>
          </a>
          <a href="#" class="metric-item" style="text-decoration: none;">
            <span class="metric-label">Caderno de Exercícios Neurais</span>
            <span class="metric-value">PDF -></span>
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
