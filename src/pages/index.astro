---
import Layout from '../layouts/Layout.astro';
---

<Layout title="OMC NEXUS - Central Kernel">
  <main class="terminal-container">
    <header class="matrix-header">
      <div class="kernel-badge">OMC NEXUS // CORE KERNEL v4.0 ACTIVE</div>
      <h1 class="main-title">Architecting Digital Reality</h1>
      <p class="main-subtitle">Sistemas integrados de performance de hardware, otimização cognitiva, expansão perceptiva e inteligência patrimonial.</p>
    </header>

    <section class="nexus-grid">
      <div class="nexus-card">
        <div>
          <span class="card-id">01</span>
          <h2>OMC Hardware Lab</h2>
          <p>Análise de métricas críticas, eficiência de VRAM e benchmarks puros.</p>
        </div>
        <span class="status-tag">Captura</span>
      </div>

      <div class="nexus-card">
        <div>
          <span class="card-id">02</span>
          <h2>SBL System</h2>
          <p>Engenharia de hábitos, mielinização e redução de latência cognitiva.</p>
        </div>
        <span class="status-tag">Otimização</span>
      </div>

      <div class="nexus-card">
        <div>
          <span class="card-id">03</span>
          <h2>Engenharia da Consciência</h2>
          <p>Modelagem lógica da percepção humana e desconstrução estrutural de ego.</p>
        </div>
        <span class="status-tag">Expansão</span>
      </div>

      <div class="nexus-card">
        <div>
          <span class="card-id">04</span>
          <h2>Imóvel em Vista</h2>
          <p>Inteligência de ativos físicos, alavancagem de crédito inteligente e consolidação.</p>
        </div>
        <span class="status-tag">Materialização</span>
      </div>
    </section>
  </main>
</Layout>

<style>
  .terminal-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 6rem 2rem;
  }
  .matrix-header {
    margin-bottom: 4rem;
    border-bottom: 1px solid #1F2937;
    padding-bottom: 2rem;
  }
  .kernel-badge {
    font-size: 0.75rem;
    color: var(--accent-gold);
    letter-spacing: 0.2em;
    font-weight: bold;
    margin-bottom: 1rem;
  }
  .main-title {
    font-size: 3rem;
    margin: 0 0 1rem 0;
    letter-spacing: -0.02em;
    font-weight: 700;
  }
  .main-subtitle {
    color: var(--text-secondary);
    max-width: 600px;
    line-height: 1.6;
    margin: 0;
  }
  .nexus-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
  }
  .nexus-card {
    background: var(--surface);
    border: 1px solid #1F2937;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 220px;
  }
  .card-id {
    font-size: 0.875rem;
    color: var(--accent-blue);
    font-weight: bold;
  }
  .nexus-card h2 {
    font-size: 1.25rem;
    margin: 1rem 0 0.5rem 0;
    font-weight: 700;
  }
  .nexus-card p {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0 0 1.5rem 0;
  }
  .status-tag {
    font-size: 0.688rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent-gold);
    border: 1px solid rgba(212, 175, 55, 0.2);
    padding: 0.25rem 0.5rem;
    align-self: flex-start;
  }
</style>
