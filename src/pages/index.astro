---
import Layout from '../layouts/Layout.astro';
import NexusCard from '../components/NexusCard.astro';

// STATE SYSTEM: A fonte da verdade para o estado do ecossistema
const systems = [
  {
    id: '01',
    title: 'OMC Hardware Lab',
    description: 'Análise de métricas críticas, eficiência de VRAM e benchmarks puros.',
    status: 'CAPTURA',
    state: 'ONLINE',
    href: '/LAB/omc-hardware-lab'
  },
  {
    id: '02',
    title: 'SBL System',
    description: 'Engenharia de hábitos, mielinização e redução de latência cognitiva.',
    status: 'OTIMIZAÇÃO',
    state: 'ACTIVE',
    href: '/LAB/sbl-system'
  },
  {
    id: '03',
    title: 'Engenharia da Consciência',
    description: 'Modelagem lógica da percepção humana e desconstrução estrutural de ego.',
    status: 'EXPANSÃO',
    state: 'EXPANDING',
    href: '/LAB/engenharia-da-consciencia'
  },
  {
    id: '04',
    title: 'Imóvel em Vista',
    description: 'Inteligência de ativos físicos, alavancagem de crédito inteligente e consolidação.',
    status: 'MATERIALIZAÇÃO',
    state: 'TRACKING',
    href: '/LAB/imovel-em-vista'
  }
];
---

<Layout title="OMC NEXUS // CORE KERNEL">
  <main class="kernel-hub">
    
    <header class="hub-header">
      <div class="system-identification">
        <span class="cursor"></span>
        OMC NEXUS // CORE KERNEL
      </div>
      <h1 class="hub-title">Reality Architecture Division</h1>
      <p class="hub-description">
        Infraestrutura operacional para performance computacional, 
        engenharia cognitiva, expansão perceptiva e materialização estratégica.
      </p>
    </header>

    <section class="system-status">
      <div class="status-label">[ SYSTEM STATUS ]</div>
      <div class="status-grid">
        {systems.map(system => (
          <div class="status-node">
            <span class="node-name">{system.title}</span>
            <span class="node-state">
              <span class="pulse"></span>
              {system.state}
            </span>
          </div>
        ))}
      </div>
    </section>

    <section class="module-grid">
      {systems.map(system => (
        <NexusCard
          id={system.id}
          title={system.title}
          description={system.description}
          status={system.status}
          href={system.href}
        />
      ))}
    </section>

    <section class="topology-section">
      <div class="topology-label">[ SYSTEM TOPOLOGY ]</div>
      <pre class="topology-map">
KERNEL
 ├── Hardware Intelligence
 │    └── Metrics / VRAM / Benchmark Systems
 │
 ├── Cognitive Infrastructure
 │    └── Habit Engineering / Focus / Execution
 │
 ├── Consciousness Engineering
 │    └── Perception / Meaning / Structural Models
 │
 └── Asset Materialization
      └── Credit / Real Estate / Consolidation
      </pre>
    </section>

  </main>

  <footer class="kernel-footer">
    <span>OMC NEXUS © 2026</span>
    <span>REALITY ARCHITECTURE DIVISION</span>
  </footer>
</Layout>

<style>
  .kernel-hub {
    display: flex;
    flex-direction: column;
    gap: 80px; /* Ritmo vertical constante */
  }

  .hub-header { display: flex; flex-direction: column; gap: 24px; }
  
  .system-identification {
    display: flex; align-items: center; gap: 8px;
    font-family: var(--font-mono); font-size: 0.75rem;
    letter-spacing: 0.18em; color: var(--accent-gold);
  }

  .cursor {
    width: 8px; height: 12px; background: var(--accent-gold);
    animation: blink 1s steps(1) infinite;
  }

  @keyframes blink { 50% { opacity: 0; } }

  .hub-title { margin: 0; font-size: clamp(2.5rem, 6vw, 4rem); line-height: 0.95; letter-spacing: -0.04em; }
  .hub-description { max-width: 720px; margin: 0; color: var(--text-secondary); line-height: 1.7; }

  .system-status {
    padding: 24px; background: var(--surface-2);
    border: 1px solid rgba(255,255,255,0.05);
  }

  .status-label, .topology-label {
    font-family: var(--font-mono); font-size: 0.72rem;
    letter-spacing: 0.18em; color: var(--text-muted); margin-bottom: 24px;
  }

  .status-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
  .status-node { display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: 0.82rem; }
  .node-state { display: flex; align-items: center; gap: 0.5rem; color: var(--accent-gold); }

  .pulse {
    width: 6px; height: 6px; border-radius: 999px;
    background: var(--accent-gold); box-shadow: 0 0 8px rgba(212,175,55,0.4);
    animation: pulse 5s infinite;
  }

  @keyframes pulse { 0%,100% { opacity: 0.6; } 50% { opacity: 1; } }

  .module-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }

  .topology-section { padding-top: 32px; border-top: 1px solid rgba(255,255,255,0.06); }
  .topology-map { margin: 0; font-family: var(--font-mono); color: var(--accent-blue); line-height: 1.9; overflow-x: auto; }

  .kernel-footer {
    display: flex; justify-content: space-between; padding-top: 32px;
    border-top: 1px solid rgba(255,255,255,0.05);
    font-family: var(--font-mono); font-size: 0.72rem; color: var(--text-muted);
  }

  @media (max-width: 900px) {
    .module-grid, .status-grid { grid-template-columns: 1fr; }
    .kernel-footer { flex-direction: column; gap: 1rem; }
  }
</style>
