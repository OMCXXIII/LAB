---
import Layout from '../../layouts/Layout.astro';

// DATA LAYER: Expanda este array conforme necessário
const inventory = [
  {
    id: 'HW-001',
    name: 'Neural Processing Unit',
    spec: 'VRAM 24GB // ECC Enabled',
    status: 'OPERATIONAL',
    link: '#'
  },
  {
    id: 'HW-002',
    name: 'Cognitive Latency Array',
    spec: 'Sub-1ms Response // Optic',
    status: 'CALIBRATING',
    link: '#'
  },
  // Adicione novos itens aqui...
];
---

<Layout title="OMC Hardware Lab // Inventory">
  <main class="lab-hub">
    
    <header class="lab-header">
      <div class="breadcrumb">[ SYSTEM // HARDWARE_LAB ]</div>
      <h1>CORE ASSETS</h1>
      <p>Repositório de infraestrutura física e benchmarks de performance.</p>
    </header>

    <section class="inventory-grid">
      {inventory.map(item => (
        <article class="asset-card">
          <div class="asset-meta">
            <span class="asset-id">{item.id}</span>
            <span class="asset-status">{item.status}</span>
          </div>
          <h2 class="asset-name">{item.name}</h2>
          <p class="asset-spec">{item.spec}</p>
          <a href={item.link} class="asset-link">ACCESS DATA →</a>
        </article>
      ))}
    </section>

  </main>
</Layout>

<style>
  .lab-hub { display: flex; flex-direction: column; gap: 64px; }
  
  .lab-header { border-bottom: 1px solid var(--surface-3); padding-bottom: 32px; }
  .breadcrumb { font-family: var(--font-mono); font-size: 0.72rem; color: var(--accent-gold); letter-spacing: 0.2em; }
  
  .inventory-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  .asset-card {
    padding: 24px;
    background: var(--surface-2);
    border: 1px solid rgba(255,255,255,0.05);
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: border 0.2s;
  }

  .asset-card:hover { border-color: var(--accent-blue); }

  .asset-meta { display: flex; justify-content: space-between; font-family: var(--font-mono); font-size: 0.7rem; }
  .asset-status { color: var(--accent-gold); }
  .asset-name { margin: 0; font-size: 1.2rem; }
  .asset-spec { font-family: var(--font-mono); font-size: 0.85rem; color: var(--text-secondary); }
  .asset-link {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  color: var(--accent-blue);
  text-decoration: none;
}
</style>
