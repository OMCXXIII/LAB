---
import Layout from '../layouts/Layout.astro';
---

<Layout title="OMC Hardware Lab // Node 01">
  <main class="module-environment">
    <nav class="system-nav">
      <a href="/LAB/" class="return-sequence">&larr; KERNEL.RETURN</a>
    </nav>

    <header class="module-header">
      <div class="hud-badge">NODE 01 // HARDWARE INTELLIGENCE</div>
      <h1 class="module-title">OMC Hardware Lab</h1>
      <p class="module-subtitle">Análise pura de performance, eficiência de VRAM, frame-times e dissipação térmica de componentes de alta performance.</p>
      
      <div class="module-stats">
        <span>STATUS: <span class="text-success">ONLINE</span></span>
        <span>BENCHMARKS: <span class="text-blue">ACTIVE</span></span>
      </div>
    </header>

    <section class="operational-grid">
      <div class="op-panel">
        <div class="panel-header">
          <h3 class="panel-title">ANÁLISE DE GPU</h3>
          <span class="pulse-indicator"></span>
        </div>
        <ul class="data-list">
          <li>
            <span class="data-label">RTX 5070 Ti - VRAM Efficiency</span>
            <span class="data-value highlight-blue">94,2%</span>
          </li>
          <li>
            <span class="data-label">RTX 4060 - TDP Max</span>
            <span class="data-value">115W</span>
          </li>
          <li>
            <span class="data-label">Frame-time Médio (1% Low)</span>
            <span class="data-value">12,4ms</span>
          </li>
        </ul>
      </div>

      <div class="op-panel">
        <div class="panel-header">
          <h3 class="panel-title">SISTEMAS E CONSOLES</h3>
          <span class="pulse-indicator"></span>
        </div>
        <ul class="data-list">
          <li>
            <span class="data-label">PlayStation 5 - Load Time</span>
            <span class="data-value highlight-gold">2,1s</span>
          </li>
          <li>
            <span class="data-label">Samsung 990 Pro - Leitura</span>
            <span class="data-value">7.450 MB/s</span>
          </li>
        </ul>
      </div>
    </section>
  </main>
</Layout>

<style>
  .module-environment {
    max-width: 1000px;
    margin: 0 auto;
    padding: 4rem 2rem;
    width: 100%;
    box-sizing: border-box;
  }

  .system-nav {
    margin-bottom: 3rem;
  }

  .return-sequence {
    font-family: monospace;
    font-size: 0.813rem;
    color: var(--text-muted, #6B7280);
    text-decoration: none;
    letter-spacing: 0.1em;
    padding: 0.5rem 1rem;
    border: 1px solid rgba(255,255,255,0.1);
    transition: all 0.2s ease;
    background: rgba(0,0,0,0.3);
  }

  .return-sequence:hover {
    color: var(--text-primary, #F5F7FA);
    border-color: var(--accent-gold, #D4AF37);
    background: rgba(212, 175, 55, 0.05);
  }

  .module-header {
    border-bottom: 1px solid rgba(255,255,255,0.06);
    padding-bottom: 2rem;
    margin-bottom: 3rem;
  }

  .hud-badge {
    font-family: monospace;
    font-size: 0.75rem;
    color: var(--accent-gold, #D4AF37);
    letter-spacing: 0.2em;
    font-weight: 700;
    margin-bottom: 1.25rem;
  }

  .module-title {
    font-size: clamp(2rem, 4vw, 3rem);
    margin: 0 0 1rem 0;
    letter-spacing: -0.02em;
  }

  .module-subtitle {
    font-size: 1.063rem;
    color: var(--text-muted, #6B7280);
    line-height: 1.6;
    max-width: 700px;
    margin: 0 0 2rem 0;
  }

  .module-stats {
    display: flex;
    gap: 2rem;
    font-family: monospace;
    font-size: 0.813rem;
    letter-spacing: 0.1em;
    background: rgba(0,0,0,0.4);
    padding: 1rem 1.5rem;
    border: 1px solid rgba(255,255,255,0.05);
    display: inline-flex;
  }

  .text-success { color: var(--accent-success, #22C55E); font-weight: bold; }
  .text-blue { color: var(--accent-blue, #6366F1); font-weight: bold; }

  .operational-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  .op-panel {
    background: linear-gradient(180deg, rgba(17,24,39,0.5), rgba(10,15,25,0.8));
    border: 1px solid rgba(255,255,255,0.06);
    padding: 2rem;
    backdrop-filter: blur(8px);
  }

  .panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    padding-bottom: 1rem;
    margin-bottom: 1.5rem;
  }

  .panel-title {
    font-family: monospace;
    font-size: 0.875rem;
    color: var(--text-primary, #F5F7FA);
    letter-spacing: 0.15em;
    margin: 0;
  }

  .pulse-indicator {
    width: 6px;
    height: 6px;
    background-color: var(--accent-blue, #6366F1);
    border-radius: 50%;
    box-shadow: 0 0 10px var(--accent-blue, #6366F1);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% { opacity: 1; }
    50% { opacity: 0.3; }
    100% { opacity: 1; }
  }

  .data-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .data-list li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.875rem 1rem;
    background: rgba(0,0,0,0.3);
    border-left: 2px solid rgba(255,255,255,0.1);
    transition: border-color 0.2s ease;
  }

  .data-list li:hover {
    border-left-color: var(--accent-gold, #D4AF37);
  }

  .data-label {
    font-size: 0.875rem;
    color: var(--text-muted, #6B7280);
  }

  .data-value {
    font-family: monospace;
    font-size: 1rem;
    font-weight: 700;
  }

  .highlight-blue { color: var(--accent-blue, #6366F1); }
  .highlight-gold { color: var(--accent-gold, #D4AF37); }

  @media (max-width: 600px) {
    .module-stats {
      flex-direction: column;
      gap: 0.75rem;
    }
    .data-list li {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
  }
</style>
