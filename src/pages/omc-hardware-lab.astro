---
import Layout from '../../layouts/Layout.astro';

import StatusBar from '../../components/StatusBar.astro';
import MetricPanel from '../../components/MetricPanel.astro';
import ProductCard from '../../components/ProductCard.astro';
import RelatedSystems from '../../components/RelatedSystems.astro';
import TopologyMap from '../../components/TopologyMap.astro';

import {
  gpuMetrics,
  storageMetrics,
  relatedSystems
} from '../../data/hardwareData';
---

<Layout title="OMC Hardware Lab">

<main class="lab-container">

  <a href="/LAB/" class="back-link">
    VOLTAR AO KERNEL
  </a>

  <header class="lab-header">

    <div class="hud-badge">
      OMC HARDWARE LAB // STATUS: ONLINE
    </div>

    <h1 class="lab-title">
      Métricas Críticas e Benchmarks
    </h1>

    <p class="lab-subtitle">
      Arquitetura computacional, eficiência térmica,
      frame-times e análise estrutural
      de hardware de elite.
    </p>

  </header>

  <StatusBar
    nodes={[
      "GPU ANALYSIS ● ONLINE",
      "CPU DATABASE ● ACTIVE",
      "BENCHMARK CORE ● RUNNING"
    ]}
  />

  <section class="dashboard-grid">

    <MetricPanel
      title="GPU Analysis"
      items={gpuMetrics}
    />

    <MetricPanel
      title="Storage Systems"
      items={storageMetrics}
    />

  </section>

  <section class="products-section">

    <div class="section-title">
      HARDWARE DATABASE
    </div>

    <div class="products-grid">

      <ProductCard
        title="RTX 5090 Benchmark"
        category="GPU"
        status="LIVE"
      />

      <ProductCard
        title="Ryzen 9800X3D Analysis"
        category="CPU"
        status="ONLINE"
      />

      <ProductCard
        title="Samsung 990 PRO"
        category="STORAGE"
        status="TRACKING"
      />

    </div>

  </section>

  <RelatedSystems
    systems={relatedSystems}
  />

  <TopologyMap
    map={`
HARDWARE DIVISION
 ├── GPUs
 ├── CPUs
 ├── Consoles
 ├── Storage
 └── Benchmarks
`}
  />

</main>

</Layout>

<style>

.lab-container{
  max-width:1200px;
  margin:0 auto;
  padding:4rem 2rem;
}

.back-link{
  color:var(--accent-gold);
  text-decoration:none;
  border:1px solid var(--accent-gold);
  padding:.6rem 1rem;
  display:inline-block;
  margin-bottom:3rem;
}

.lab-header{
  margin-bottom:3rem;
  border-bottom:1px solid rgba(212,175,55,.2);
  padding-bottom:2rem;
}

.hud-badge{
  color:var(--accent-blue);
  font-size:.75rem;
  letter-spacing:.2em;
  margin-bottom:1rem;
}

.lab-title{
  font-size:3rem;
  margin:0 0 1rem 0;
}

.lab-subtitle{
  max-width:700px;
  line-height:1.7;
  color:var(--text-secondary);
}

.dashboard-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(320px,1fr));
  gap:2rem;
}

.products-section{
  margin-top:5rem;
}

.section-title{
  margin-bottom:2rem;
  font-size:.9rem;
  letter-spacing:.15em;
  color:var(--accent-gold);
}

.products-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
  gap:1.5rem;
}

</style>
