---
import Layout from '../../layouts/Layout.astro';

const inventory = [
  {
    id: 'HW-001',
    name: 'Neural Processing Unit',
    spec: 'VRAM 24GB // ECC Enabled',
    status: 'OPERATIONAL',
    benchmark: 98,
    category: 'AI Compute',
    link: '#'
  },
  {
    id: 'HW-002',
    name: 'Cognitive Latency Array',
    spec: 'Sub-1ms Response // Optic',
    status: 'CALIBRATING',
    benchmark: 74,
    category: 'Optical Systems',
    link: '#'
  },
  {
    id: 'HW-003',
    name: 'Quantum Relay Node',
    spec: '128TB/s Throughput',
    status: 'OFFLINE',
    benchmark: 12,
    category: 'Network Core',
    link: '#'
  }
];

const getStatusClass = (status) => {
  switch(status) {
    case 'OPERATIONAL': return 'status-green';
    case 'CALIBRATING': return 'status-yellow';
    case 'OFFLINE': return 'status-red';
    default: return '';
  }
};
---

<Layout title="OMC Hardware Lab // Inventory">

  <main class="lab-hub">

    <header class="lab-header">
      <div class="breadcrumb">
        [ SYSTEM // HARDWARE_LAB ]
      </div>

      <h1>CORE ASSETS</h1>

      <p>
        Repositório de infraestrutura física e benchmarks de performance.
      </p>

      <div class="lab-stats">
        <div class="stat-box">
          <span class="stat-value">128</span>
          <span class="stat-label">ACTIVE NODES</span>
        </div>

        <div class="stat-box">
          <span class="stat-value">99.92%</span>
          <span class="stat-label">UPTIME</span>
        </div>

        <div class="stat-box">
          <span class="stat-value">24.8 PF</span>
          <span class="stat-label">COMPUTE</span>
        </div>
      </div>
    </header>

    <section class="inventory-grid">

      {inventory.map(item => (
        <article class="asset-card">

          <div class="asset-topline">
            <span class="asset-id">{item.id}</span>

            <span class={`asset-status ${getStatusClass(item.status)}`}>
              {item.status}
            </span>
          </div>

          <div class="asset-category">
            {item.category}
          </div>

          <h2 class="asset-name">{item.name}</h2>

          <p class="asset-spec">{item.spec}</p>

          <div class="benchmark-section">
            <div class="benchmark-meta">
              <span>PERFORMANCE INDEX</span>
              <span>{item.benchmark}%</span>
            </div>

            <div class="benchmark-bar">
              <div
                class="benchmark-fill"
                style={`width:${item.benchmark}%`}
              />
            </div>
          </div>

          <a href={item.link} class="asset-link">
            ACCESS DATA →
          </a>

        </article>
      ))}

    </section>

  </main>

</Layout>

<style>

  .lab-hub {
    display: flex;
    flex-direction: column;
    gap: 72px;
    position: relative;
  }

  .lab-hub::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: -1;
  }

  .lab-header {
    border-bottom: 1px solid var(--surface-3);
    padding-bottom: 40px;
  }

  .breadcrumb {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--accent-gold);
    letter-spacing: 0.25em;
    margin-bottom: 12px;
  }

  .lab-header h1 {
    margin: 0;
    font-size: clamp(3rem, 6vw, 5rem);
    line-height: 0.95;
  }

  .lab-header p {
    max-width: 620px;
    color: var(--text-secondary);
    margin-top: 16px;
  }

  .lab-stats {
    display: flex;
    gap: 20px;
    margin-top: 40px;
    flex-wrap: wrap;
  }

  .stat-box {
    background: var(--surface-2);
    border: 1px solid rgba(255,255,255,0.05);
    padding: 18px 22px;
    min-width: 180px;
  }

  .stat-value {
    display: block;
    font-size: 1.6rem;
    font-weight: 700;
  }

  .stat-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-secondary);
    letter-spacing: 0.15em;
  }

  .inventory-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 24px;
  }

  .asset-card {
    position: relative;
    padding: 28px;
    background:
      linear-gradient(
        180deg,
        rgba(255,255,255,0.02),
        rgba(255,255,255,0.01)
      );

    border: 1px solid rgba(255,255,255,0.06);

    display: flex;
    flex-direction: column;
    gap: 18px;

    transition:
      transform 0.25s ease,
      border-color 0.25s ease,
      box-shadow 0.25s ease;
  }

  .asset-card:hover {
    transform: translateY(-4px);

    border-color: rgba(77,163,255,0.45);

    box-shadow:
      0 0 0 1px rgba(77,163,255,0.15),
      0 12px 40px rgba(0,0,0,0.45),
      0 0 40px rgba(77,163,255,0.08);
  }

  .asset-topline {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .asset-id {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-secondary);
    letter-spacing: 0.12em;
  }

  .asset-status {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 6px 10px;
    border-radius: 999px;
    border: 1px solid currentColor;
  }

  .status-green {
    color: #6CFFB2;
  }

  .status-yellow {
    color: #FFD76C;
  }

  .status-red {
    color: #FF6C6C;
  }

  .asset-category {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--accent-blue);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .asset-name {
    margin: 0;
    font-size: 1.4rem;
    line-height: 1.1;
  }

  .asset-spec {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .benchmark-section {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .benchmark-meta {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-secondary);
  }

  .benchmark-bar {
    height: 8px;
    background: rgba(255,255,255,0.05);
    overflow: hidden;
    border-radius: 999px;
  }

  .benchmark-fill {
    height: 100%;
    background: linear-gradient(
      90deg,
      var(--accent-blue),
      #7BE7FF
    );
  }

  .asset-link {
    margin-top: auto;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent-blue);
    text-decoration: none;
    letter-spacing: 0.08em;
  }

  .asset-link:hover {
    opacity: 0.8;
  }

</style>
