---
import Layout from '../layouts/Layout.astro';
---

<Layout title="SBL System // Otimização Biológica">
  <main class="lab-container">
    <header class="lab-header">
      <a href="/LAB/" class="back-link">VOLTAR AO KERNEL</a>
      <div class="hud-badge">SBL SYSTEM // STATUS: OTIMIZAÇÃO</div>
      <h1 class="lab-title">Arquitetura de Hábitos & Baixa Latência</h1>
      <p class="lab-subtitle">Sistemas de redução de latência biológica e engenharia de foco estruturado.</p>
    </header>

    <section class="dashboard-grid">
      <div class="data-panel">
        <div class="panel-header">
          <h2>Protocolos e Volumes</h2>
          <span class="pulse-indicator"></span>
        </div>
        <div class="metrics-list">
          <a href="#" class="metric-item" style="text-decoration: none;">
            <span class="metric-label">SBL Volume 1: Fundamentos</span>
            <span class="metric-value">ACESSAR -></span>
          </a>
          <a href="#" class="metric-item" style="text-decoration: none;">
            <span class="metric-label">SBL Volume 2: Implementação</span>
            <span class="metric-value">ACESSAR -></span>
          </a>
          <a href="#" class="metric-item" style="text-decoration: none;">
            <span class="metric-label">SBL Volume 3: Maestria</span>
            <span class="metric-value">ACESSAR -></span>
          </a>
        </div>
      </div>

      <div class="data-panel">
        <div class="panel-header">
          <h2>Ferramentas de Foco</h2>
          <span class="pulse-indicator"></span>
        </div>
        <div class="metrics-list">
          <a href="#" class="metric-item" style="text-decoration: none;">
            <span class="metric-label">Mapeamento de Hábitos (PDF)</span>
            <span class="metric-value">DOWNLOAD</span>
          </a>
          <div class="metric-item">
            <span class="metric-label">Taxa de Adesão Média</span>
            <span class="metric-value">87.4%</span>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
