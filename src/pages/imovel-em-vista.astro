---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Imóvel in Vista // Materialização">
  <main class="lab-container">
    <header class="lab-header">
      <a href="/LAB/" class="back-link">VOLTAR AO KERNEL</a>
      <div class="hud-badge">IMÓVEL IN VISTA // STATUS: MATERIALIZAÇÃO</div>
      <h1 class="lab-title">Inteligência Estratégica e Crédito</h1>
      <p class="lab-subtitle">Gestão de ativos físicos, engenharia de crédito estruturado e estabilidade patrimonial.</p>
    </header>

    <section class="dashboard-grid">
      <div class="data-panel">
        <div class="panel-header">
          <h2>Análise de Portfólio</h2>
          <span class="pulse-indicator"></span>
        </div>
        <div class="metrics-list">
          <a href="#" class="metric-item" style="text-decoration: none;">
            <span class="metric-label">Solicitar Análise de Crédito</span>
            <span class="metric-value">INICIAR -></span>
          </a>
          <a href="#" class="metric-item" style="text-decoration: none;">
            <span class="metric-label">Consultoria Imobiliária</span>
            <span class="metric-value">AGENDAR -></span>
          </a>
        </div>
      </div>

      <div class="data-panel">
        <div class="panel-header">
          <h2>Hospedagem de Matérias</h2>
          <span class="pulse-indicator"></span>
        </div>
        <div class="metrics-list">
          <a href="#" class="metric-item" style="text-decoration: none;">
            <span class="metric-label">Guia: Estruturação de Financiamento</span>
            <span class="metric-value">LER -></span>
          </a>
          <a href="#" class="metric-item" style="text-decoration: none;">
            <span class="metric-label">Métricas de Mercado Atual (RJ)</span>
            <span class="metric-value">VER DADOS</span>
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
