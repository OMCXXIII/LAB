{
  "name": "omc-nexus-core",
  "private": true,
  "version": "1.0.0",
  "description": "Kernel e Infraestrutura Central do Ecossistema OMC NEXUS",
  "author": "OMCXXIII",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "astro build",
    "dev": "astro dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "dependencies": {
    "@astrojs/mdx": "^3.1.3",
    "astro": "^4.11.3"
  },
  "devDependencies": {
    "@biomejs/biome": "1.8.3",
    "turbo": "2.0.14",
    "typescript": "5.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.1.4"
}
